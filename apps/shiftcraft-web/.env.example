# Auth.js requires a session-signing secret. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Database connection — shared with Tracey LMS. In dev, point at the same
# Postgres your lms-web app uses (the @tracey/db package reads this).
DATABASE_URL=

# Optional. Trust proxy in production behind a reverse proxy / Vercel.
# AUTH_TRUST_HOST=true

# HMAC secrets for kiosk cookies. Both required when /kiosk/* is in use.
# Generate each independently — don't reuse the same value:
#   openssl rand -base64 48
# KIOSK_DEVICE_SECRET signs the long-lived device cookie issued at pair time.
# KIOSK_ACTOR_SECRET signs the 60-sec post-PIN actor cookie.
KIOSK_DEVICE_SECRET=
KIOSK_ACTOR_SECRET=
