# Tracey planning-web — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Supabase (transitional — used during Phase 4 migration only) ───
# Find these in your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App URL ───
NEXT_PUBLIC_SITE_URL=http://localhost:4300

# ─── Storage adapter (Slice 7) ───
# Pick the backend explicitly, or leave unset for auto-detection:
#   STORAGE_BACKEND=local-fs  → writes under LOCAL_STORAGE_DIR (dev default)
#   STORAGE_BACKEND=r2        → writes to Cloudflare R2 via the S3 API
# When unset: R2 if all three of R2_ACCOUNT_ID / R2_ACCESS_KEY_ID / R2_BUCKET
# are set, otherwise local-fs.
STORAGE_BACKEND=

# Local-FS backend (dev): where to put files on disk. Relative paths resolve
# from `process.cwd()`. The /api/storage/serve route HMAC-signs URLs with
# STORAGE_SIGNING_SECRET (falls back to NEXTAUTH_SECRET).
LOCAL_STORAGE_DIR=.tracey-storage
STORAGE_SIGNING_SECRET=
# Set when the app is reverse-proxied (e.g. signed URLs need a public origin)
STORAGE_PUBLIC_BASE_URL=

# R2 backend (prod / staging). Cloudflare → R2 → API Tokens → create an
# Object-Read-Write token scoped to the bucket(s) you create below.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Default bucket name. Per-logical-bucket overrides:
#   R2_BUCKET_ITEM_IMAGES, R2_BUCKET_ITEM_SPECS, R2_BUCKET_TENANT_BRANDING,
#   R2_BUCKET_SPEC_IMAGES, R2_BUCKET_MACHINE_DOCS, R2_BUCKET_SUPPLIER_CERTS
# Operators commonly point all six at one R2 bucket and use R2_BUCKET_PREFIX
# to namespace keys.
R2_BUCKET=
R2_BUCKET_PREFIX=
