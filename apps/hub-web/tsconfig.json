{
  "extends": "@tracey/config/tsconfig.base",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "noEmit": true,
    "allowJs": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "~/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
