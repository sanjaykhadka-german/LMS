# Copy to .env.test.local (gitignored) and fill in.
# Used by `pnpm --filter lms-web test:e2e` and the Playwright global setup.

# Required: an admin/owner account on the running dev server.
E2E_EMAIL=
E2E_PASSWORD=

# Optional: override the dev server URL (default http://localhost:4000).
# E2E_BASE_URL=http://localhost:4000

# Optional: setting this enables the destructive password-change spec which
# round-trips your password (E2E_PASSWORD -> here -> back to E2E_PASSWORD).
# Leave blank to skip.
E2E_PASSWORD_NEW=

# Optional: overrides for the cross-tenant-isolation spec. The spec
# auto-seeds a second tenant + admin user on first run via
# tests/e2e/_setup/tenant-b.ts; these envs let you point it at different
# values if you already have a second tenant set up.
# E2E_TENANT_B_EMAIL=tenant-b-admin@example.test
# E2E_TENANT_B_PASSWORD=tenant-b-pass-1
# E2E_TENANT_B_SLUG=tenant-b-isolation-test
# E2E_TENANT_B_NAME=Tenant B (isolation test)
