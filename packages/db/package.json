{
  "name": "@tracey/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./client": "./src/client.ts",
    "./shiftcraft-schema": "./src/shiftcraft-schema.ts",
    "./planning-schema": "./src/planning-schema.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "generate-shiftcraft": "drizzle-kit generate --config drizzle.config.shiftcraft.ts",
    "generate-planning": "drizzle-kit generate --config drizzle.config.planning.ts",
    "migrate": "tsx src/migrate.ts",
    "migrate-shiftcraft": "tsx src/migrate-shiftcraft.ts",
    "migrate-planning": "tsx src/migrate-planning.ts",
    "migrate-tenants": "tsx src/per-tenant-migrate.ts",
    "tenant-backup": "tsx src/cli/tenant-backup.ts",
    "tenant-provision": "tsx src/cli/tenant-provision.ts",
    "tenant-copy": "tsx src/cli/tenant-copy.ts",
    "tenant-freeze": "tsx src/cli/tenant-freeze.ts",
    "tenant-unfreeze": "tsx src/cli/tenant-unfreeze.ts",
    "reset": "tsx src/reset.ts",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@tracey/config": "workspace:*",
    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
