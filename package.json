{
  "name": "tracey-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @tracey/db run generate",
    "db:generate-shiftcraft": "pnpm --filter @tracey/db run generate-shiftcraft",
    "db:migrate": "pnpm --filter @tracey/db run migrate",
    "db:migrate-shiftcraft": "pnpm --filter @tracey/db run migrate-shiftcraft",
    "db:migrate-tenants": "pnpm --filter @tracey/db run migrate-tenants",
    "db:reset": "pnpm --filter @tracey/db run reset",
    "db:studio": "pnpm --filter @tracey/db run studio",
    "db:tenant-backup": "pnpm --filter @tracey/db run tenant-backup",
    "db:tenant-provision": "pnpm --filter @tracey/db run tenant-provision",
    "db:tenant-copy": "pnpm --filter @tracey/db run tenant-copy",
    "db:tenant-freeze": "pnpm --filter @tracey/db run tenant-freeze",
    "db:tenant-unfreeze": "pnpm --filter @tracey/db run tenant-unfreeze"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  }
}
