# ─── Flask (existing LMS service) ───
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///lms.db
RESEND_API_KEY=
MAIL_FROM=training@germanbutchery.com.au
MAIL_FROM_NAME=German Butchery Training
APP_BASE_URL=http://localhost:5000
ADMIN_EMAIL=sanjay.khadka@germanbutchery.com.au
PASS_THRESHOLD=80
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# Leave blank to auto-pick (claude if CLAUDE_API_KEY set, else gemini),
# or force "claude" or "gemini".
AI_PROVIDER=

# ─── Next.js (lms-web) — Phase 1 ───
# Clerk (https://dashboard.clerk.com — application API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Stripe (https://dashboard.stripe.com — developers / API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs — create products in dashboard with metadata.plan = starter|pro|enterprise
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# Public origin of lms-web (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Where the existing Flask LMS lives — used by the dashboard "Open Training" link
FLASK_BASE_URL=http://localhost:5000

# Shared secret used by Phase 2 SSO bridge (already provisioned for forward compatibility)
LMS_SSO_SECRET=change-me-to-a-long-random-string
