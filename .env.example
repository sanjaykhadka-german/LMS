# ─── Flask (existing LMS service) ───
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///lms.db
RESEND_API_KEY=
MAIL_FROM=training@germanbutchery.com.au
MAIL_FROM_NAME=German Butchery Training
APP_BASE_URL=http://localhost:5000
ADMIN_EMAIL=sanjay.khadka@germanbutchery.com.au
PASS_THRESHOLD=80
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# Leave blank to auto-pick (claude if CLAUDE_API_KEY set, else gemini),
# or force "claude" or "gemini".
AI_PROVIDER=

# ─── Next.js (lms-web) — Phase 1 ───
# Auth.js v5 — self-hosted auth (replaces Clerk)
# Generate AUTH_SECRET locally with: npx auth secret
AUTH_SECRET=replace-me-with-32-bytes-of-random-base64
# Origin Auth.js sends cookies / redirects from. Required for non-Vercel hosts.
AUTH_URL=http://localhost:4000
# Render (and any non-Vercel host) requires this to allow proxied request hosts.
AUTH_TRUST_HOST=true

# Stripe (https://dashboard.stripe.com — developers / API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs — for each plan create one product with TWO prices:
#   - Recurring monthly  (USD 19 for Starter, USD 39 for Pro)
#   - Recurring yearly   (USD 182.40 for Starter, USD 374.40 for Pro — 20% off)
# Both prices on a product should set metadata.plan = starter | pro
# (the webhook handler reads price.metadata.plan to update the tenant row).
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

# Public origin of lms-web (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Where the existing Flask LMS lives — used by the dashboard "Open Training" link
FLASK_BASE_URL=http://localhost:5000

# Shared secret used by Phase 2 SSO bridge (already provisioned for forward compatibility)
LMS_SSO_SECRET=change-me-to-a-long-random-string
